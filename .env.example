# ─── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Nylas (Email & Calendar) ────────────────────────────────────────────────
# v3: no client_id/secret — the API key IS the client identifier
NYLAS_API_KEY=
NYLAS_API_URI=https://api.us.nylas.com
NYLAS_REDIRECT_URI=http://localhost:3001/integrations/nylas/callback

# ─── Platform AI — COKI Studio pays for this, users never see it ─────────────
# Platform API key — COKI Studio pays for this, users never see it
ANTHROPIC_API_KEY=
# xAI Grok API key — used for web and Twitter/X search
GROK_API_KEY=

# ─── Twilio (SMS + WhatsApp) ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=whatsapp:+17204776021

# ─── Slack ─────────────────────────────────────────────────────────────────────
# Optional: Socket Mode app token (xapp-…) if you prefer Socket Mode over HTTP
SLACK_APP_TOKEN=

# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ─── Monday.com ───────────────────────────────────────────────────────────────
MONDAY_API_TOKEN=

# ─── Planning Center ──────────────────────────────────────────────────────────
PLANNING_CENTER_CLIENT_ID=
PLANNING_CENTER_CLIENT_SECRET=
PLANNING_CENTER_REDIRECT_URI=http://localhost:3001/integrations/planningcenter/callback

# ─── ElevenLabs (Text-to-Speech for audio briefings) ─────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# ─── Encryption ──────────────────────────────────────────────────────────────
# 32-byte hex string for AES-256 encryption of stored credentials
ENCRYPTION_KEY=

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# URL of the React frontend — used for OAuth redirect targets
FRONTEND_URL=http://localhost:5173

# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
